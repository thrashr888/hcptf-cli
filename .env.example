TFE_ADDRESS=https://app.terraform.io
TFE_TOKEN=
TFE_ORG=

# hcptf-specific values can be used when they should differ from Terraform CLI.
# HCPTF_ADDRESS=https://tfe.example.com
# HCPTF_TOKEN=
# HCPTF_ORG=

# Env files are loaded without overriding exported variables.
# Discovery order:
# 1. --env-file / HCPTF_ENV_FILE
# 2. .env in the current directory, then ancestor directories
# 3. ~/.hcptf.env
# 4. ~/.config/hcptf/env
